[Unit]
Description=TKE RAG Challenge FastAPI app
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/rag-challenge
EnvironmentFile=/opt/rag-challenge/.env
Environment=HOST=127.0.0.1
Environment=PORT=8000
ExecStart=/usr/bin/python3 -m app.standalone
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
